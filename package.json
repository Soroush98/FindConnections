{
  "name": "findconnections",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --experimental-https",
    "dev:http": "next dev --turbopack",
    "check:neo4j": "node --env-file=.env -e \"const neo4j=require('neo4j-driver');const uri=process.env.NEO4J_URI||'neo4j+ssc://neo4j.findconnections.net:7687';const d=neo4j.driver(uri,neo4j.auth.basic(process.env.NEO4J_USER,process.env.NEO4J_PASSWORD));d.verifyConnectivity().then(()=>{console.log('Neo4j connectivity OK')}).catch((e)=>{console.error('Neo4j connectivity FAILED:',e.code||e.name,e.message);process.exitCode=1}).finally(()=>d.close())\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed:admin": "tsx scripts/seed-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1047.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@mui/material": "^6.4.3",
    "@supabase/supabase-js": "^2.105.4",
    "@vercel/analytics": "^1.5.0",
    "bcrypt": "^6.0.0",
    "framer-motion": "^12.4.3",
    "jsonwebtoken": "^9.0.2",
    "neo4j-driver": "^5.28.0",
    "next": "^16.2.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.1",
    "zod": "^4.1.13"
  },
  "overrides": {
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.0",
    "typescript": "^5.8.2"
  }
}
